---
# inventory/vault.yml - CIFRARE CON: ansible-vault encrypt inventory/vault.yml
#
# Credenziali OpenWISP - non committare mai in chiaro.
# Struttura a dizionario: una entry per organizzazione.

# Credenziali API OpenWISP Firmware Upgrader
openwisp_username: "admin"
openwisp_password: "changeme"

# shared_secret openwisp-config per organizzazione.
# Deve corrispondere al valore impostato nell'organizzazione su OpenWISP Controller.
# Aggiungere una entry per ogni org definita in ninux.yml (sezione openwisp_orgs).
vault_openwisp_secrets:
  basilicata: "Secretn1nuxB4s"
  # roma: "SecretRomaXyz"
  # torino: "SecretTorinoXyz"
