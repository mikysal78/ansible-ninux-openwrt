# inventory/vault.yml.example
#
# NON esiste più un vault.yml separato.
# Le stringhe sensibili sono cifrate inline in ninux.yml
# con ansible-vault encrypt_string.
#
# Per generare una stringa cifrata da inserire in ninux.yml:
#
#   ansible-vault encrypt_string \
#     --vault-password-file /var/lib/jenkins/.vault_pass \
#     'VALORE_DA_CIFRARE' --name 'NOME_VARIABILE'
#
# Esempio — shared_secret per basilicata:
#
#   ansible-vault encrypt_string \
#     --vault-password-file /var/lib/jenkins/.vault_pass \
#     'Secretn1nuxB4s' --name 'shared_secret'
#
# Output da incollare in ninux.yml sotto openwisp_orgs.basilicata:
#
#   shared_secret: !vault |
#         $ANSIBLE_VAULT;1.1;AES256
#         66386439653236336462626566653337...
#
# Esempio — credenziali Firmware Upgrader:
#
#   ansible-vault encrypt_string \
#     --vault-password-file /var/lib/jenkins/.vault_pass \
#     'admin' --name 'openwisp_username'
#
#   ansible-vault encrypt_string \
#     --vault-password-file /var/lib/jenkins/.vault_pass \
#     'MyPassword123' --name 'openwisp_password'
