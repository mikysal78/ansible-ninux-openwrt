---
# =============================================================================
# ninux.yml.example  —  Template di configurazione Ninux OpenWrt Build System
#
# ISTRUZIONI PER UNA NUOVA INSTALLAZIONE:
#   1. Copia questo file come ninux.yml nella root del repo
#      cp ninux.yml.example ninux.yml
#
#   2. Modifica ninux.yml con i valori della tua organizzazione
#
#   3. Genera le stringhe cifrate per i campi contrassegnati con !vault:
#      ansible-vault encrypt_string \
#        --vault-password-file /var/lib/jenkins/.vault_pass \
#        'IL_TUO_VALORE' --name 'NOME_CAMPO'
#      Incolla l'output al posto del blocco PLACEHOLDER corrispondente.
#
#   4. Committa ninux.yml nel repo — i valori sensibili sono cifrati inline
#      e sicuri da versionare. Solo chi ha il vault_pass può decifrarli.
# =============================================================================


# -----------------------------------------------------------------------------
# BUILD — Versione e organizzazione
# -----------------------------------------------------------------------------

# Tag OpenWrt da compilare (es. v25.12.4, v24.10.0, snapshot)
openwrt_version: "v25.12.4"

# Organizzazione Ninux attiva — corrisponde a config/organizations/<org>/
openwrt_org: "default"

# Varianti VPN da compilare per ogni device
# Valori possibili: NO, ZeroTier, WireGuard, DualVPN
openwrt_vpn_variants:
  - "NO"
  - "ZeroTier"
  - "WireGuard"
  - "DualVPN"

# Compila anche le varianti con Captive Portal (raddoppia le build)
openwrt_cp_variants: true


# -----------------------------------------------------------------------------
# OPENWISP-CONFIG — Configurazione agente per organizzazione
#
# Aggiungere una sezione per ogni org Ninux.
# shared_secret DEVE essere cifrata con ansible-vault encrypt_string.
# Se un'org non è definita qui, la build salta /etc/config/openwisp.
#
# Per generare shared_secret cifrata:
#   ansible-vault encrypt_string \
#     --vault-password-file /var/lib/jenkins/.vault_pass \
#     'LA_TUA_SECRET' --name 'shared_secret'
# -----------------------------------------------------------------------------

openwisp_orgs:
  default:
    controller_url: "https://openwisp.ninux-nnxx.it"
    management_interface: "owz12345"
    shared_secret: !vault |
          $ANSIBLE_VAULT;1.1;AES256
          # PLACEHOLDER — ansible-vault encrypt_string ... 'LA_SECRET' --name 'shared_secret'
    api_token: !vault |
          $ANSIBLE_VAULT;1.1;AES256
          # PLACEHOLDER — Token API utente OpenWISP per org default
          # Admin OpenWISP → Users → <utente org> → API Keys
          # ansible-vault encrypt_string ... 'IL_TOKEN' --name 'api_token'
  # roma:
  #   controller_url: "https://openwisp.ninux-nnxx.it"
  #   management_interface: "owzABCDE"
  #   shared_secret: !vault |
  #         $ANSIBLE_VAULT;1.1;AES256
  #         # PLACEHOLDER
  #   api_token: !vault |
  #         $ANSIBLE_VAULT;1.1;AES256
  #         # PLACEHOLDER


# -----------------------------------------------------------------------------
# OPENWISP Firmware Upgrader — Upload automatico dopo la build
# -----------------------------------------------------------------------------

# Abilita upload automatico su OpenWISP dopo la build
openwisp_upload_enabled: false

# URL base dell'istanza OpenWISP Firmware Upgrader (es. https://openwisp.example.org)
openwisp_url: ""

# Slug dell'organizzazione OpenWISP (nome breve, es. "default")
# NON necessariamente uguale a openwrt_org
openwisp_org_slug: "default"

# UUID dell'organizzazione OpenWISP (cifrato con encrypt_string)
# Recuperabile da: Admin OpenWISP → Organizations → <org> → URL
# ansible-vault encrypt_string --vault-password-file /var/lib/jenkins/.vault_pass \
#   'xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx' --name 'openwisp_org_id'
openwisp_org_id: !vault |
      $ANSIBLE_VAULT;1.1;AES256
      # PLACEHOLDER — sostituire con output di encrypt_string

# Nome della category firmware in OpenWISP
openwisp_category_name: "Ninux {{ openwrt_org | capitalize }} - {{ openwrt_target }}"

# Avvia batch upgrade su tutti i device dopo l'upload
openwisp_trigger_upgrade: false

# Limita upgrade a un device group specifico (UUID OpenWISP), vuoto = tutti
openwisp_upgrade_group: ""



# -----------------------------------------------------------------------------
# GITHUB RELEASE — Pubblicazione firmware come release GitHub
#
# Prerequisiti:
#   1. Personal Access Token GitHub con permesso Contents: Read and Write
#      su https://github.com/settings/tokens
#   2. Token salvato in Jenkins → Manage Jenkins → Credentials
#      Kind: Secret text  |  ID: github-release-token
# -----------------------------------------------------------------------------

# Abilita creazione release GitHub dopo la build
github_release_enabled: false

# Repository GitHub (owner/repo)
github_repo: "mikysal78/ansible-ninux-openwrt"

# Crea come pre-release (consigliato durante i test)
github_prerelease: false

# Includi file sha256sums come asset della release
github_release_include_sha256: true



# -----------------------------------------------------------------------------
# PERFORMANCE — ccache
# -----------------------------------------------------------------------------

# Abilita ccache (riduce del ~70% il tempo dalla seconda build)
openwrt_ccache_enabled: true

# Percorso ccache fuori dal workspace Jenkins (sopravvive tra i job)
openwrt_ccache_dir: "/var/cache/openwrt-ccache"

# Dimensione massima ccache
openwrt_ccache_maxsize: "20G"


# -----------------------------------------------------------------------------
# PERFORMANCE — tmpfs (RAM disk per directory temporanee)
# -----------------------------------------------------------------------------

# Monta tmp/ su RAM disk (+30-40% velocità su I/O)
openwrt_tmpfs_enabled: true
openwrt_tmpfs_size: "8G"
openwrt_tmpfs_path: "/mnt/openwrt-tmpfs"


# -----------------------------------------------------------------------------
# PULIZIA
# -----------------------------------------------------------------------------

# Rimuovi staging_dir/build_dir dopo ogni device (risparmio ~5-10GB disco)
openwrt_cleanup_after_build: true

# Rimuovi sorgenti OpenWrt al termine (false = più veloce alla build successiva)
openwrt_cleanup_sources: false


# =============================================================================
# — Le variabili sotto raramente vanno modificate —
# =============================================================================

# -----------------------------------------------------------------------------
# PERCORSI
# -----------------------------------------------------------------------------

openwrt_work_dir: "{{ playbook_dir }}/.."
openwrt_build_basedir: "{{ openwrt_work_dir }}/build"
openwrt_output_dir: "{{ openwrt_work_dir }}/output"
openwrt_nfs_dir: "/mnt/nfs-firmware"
openwrt_config_local_path: "{{ openwrt_work_dir }}/config"
openwrt_ninux_src_dir: "{{ openwrt_build_basedir }}/ninux-configs"
openwrt_src_dir: "{{ openwrt_build_basedir }}/openwrt"


# -----------------------------------------------------------------------------
# COMPILAZIONE
# -----------------------------------------------------------------------------

openwrt_upstream_repo: "https://github.com/openwrt/openwrt.git"

# Numero di job make paralleli (0 = automatico: nproc + extra)
openwrt_make_jobs: 0
openwrt_make_jobs_extra: 2

# Target che richiedono clean build forzato (bug noti OpenWrt)
openwrt_clean_build_targets:
  - "lamobo_R1"
  - "tplink_c2600"


# -----------------------------------------------------------------------------
# FEEDS aggiuntivi
# -----------------------------------------------------------------------------

openwrt_feeds:
  - "src-git chilli https://github.com/mikysal78/coova-chilli-openwrt.git"
  - "src-git openwisp_config https://github.com/openwisp/openwisp-config.git"
  - "src-git openwisp_monitoring https://github.com/openwisp/openwrt-openwisp-monitoring.git"
  - "src-git zerotier https://github.com/mwarning/zerotier-openwrt.git"

openwrt_remove_packages:
  - "package/feeds/luci/luci-app-apinger"


# -----------------------------------------------------------------------------
# DIPENDENZE DI BUILD (apt)
# Modificare solo se si usa una distribuzione non standard
# -----------------------------------------------------------------------------

openwrt_build_deps:
  - build-essential
  - ccache
  - time
  - git
  - subversion
  - g++
  - bash
  - make
  - libssl-dev
  - patch
  - libncurses-dev
  - zlib1g-dev
  - gawk
  - flex
  - gettext
  - wget
  - unzip
  - xz-utils
  - python3
  - python3-distutils-extra
  - rsync
  - curl
  - libsnmp-dev
  - liblzma-dev
  - libpam0g-dev
  - cpio

