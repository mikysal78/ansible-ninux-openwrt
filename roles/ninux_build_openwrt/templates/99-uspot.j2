#!/bin/sh
# Generated by Ansible (ninux_build_openwrt role)
# Captive Portal uspot for {{ openwrt_org }}
#
# Alternativa a coova-chilli (99-br-cp): uspot usa firewall4/nftables.
# Rete captive: {{ uspot_network }}.0/24, gateway {{ uspot_gateway }}

uci -q batch <<-EOF >/dev/null
# --- Bridge e interfaccia captive ---
set network.device_CP=device
set network.device_CP.name='br-cp'
set network.device_CP.type='bridge'
set network.device_CP.bridge_empty='1'
set network.device_CP.ports='cpwlan0'
set network.device_CP.igmp_snooping='0'
set network.device_CP.mtu='1500'
set network.CP=interface
set network.CP.auto='1'
set network.CP.device='br-cp'
set network.CP.proto='static'
set network.CP.ipaddr='{{ uspot_gateway }}'
set network.CP.netmask='255.255.255.0'
commit network

# --- DHCP sulla rete captive ---
set dhcp.CP=dhcp
set dhcp.CP.interface='CP'
set dhcp.CP.start='100'
set dhcp.CP.limit='150'
set dhcp.CP.leasetime='1h'
commit dhcp

# --- Zona firewall captive (nftables) ---
set firewall.CP=zone
set firewall.CP.name='captive'
set firewall.CP.network='CP'
set firewall.CP.input='REJECT'
set firewall.CP.output='ACCEPT'
set firewall.CP.forward='REJECT'
set firewall.CP_fwd=forwarding
set firewall.CP_fwd.src='captive'
set firewall.CP_fwd.dest='wan'
commit firewall

# --- Portale uspot ---
set uspot.CP=uspot
set uspot.CP.auth_mode='click-to-continue'
set uspot.CP.interface='CP'
set uspot.CP.setname='uspot'
set uspot.CP.idle_timeout='600'
set uspot.CP.session_timeout='86400'
set uspot.CP.debug='0'
commit uspot

# --- uhttpd: pagine del portale ---
delete uhttpd.uspot
set uhttpd.uspot=uhttpd
add_list uhttpd.uspot.listen_http='{{ uspot_gateway }}:80'
set uhttpd.uspot.redirect_https='0'
set uhttpd.uspot.home='/usr/share/uspot'
set uhttpd.uspot.max_requests='5'
set uhttpd.uspot.no_dirlists='1'
add_list uhttpd.uspot.ucode_prefix='/hotspot=/usr/share/uspot/handler.uc'
commit uhttpd
EOF
